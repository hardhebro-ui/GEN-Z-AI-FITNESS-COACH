{
  "entities": {
    "Plan": {
      "title": "Plan",
      "description": "A generated fitness and diet plan.",
      "type": "object",
      "properties": {
        "inputs": {
          "type": "object",
          "description": "The user inputs used to generate the plan."
        },
        "plan": {
          "type": "object",
          "description": "The generated plan data."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the plan was generated."
        },
        "downloads": {
          "type": "integer",
          "description": "Number of times the plan has been downloaded."
        }
      },
      "required": ["inputs", "plan", "createdAt"]
    },
    "Stats": {
      "title": "Stats",
      "description": "Global application statistics.",
      "type": "object",
      "properties": {
        "totalPlans": {
          "type": "integer",
          "description": "Total number of plans generated."
        },
        "totalReviews": {
          "type": "integer",
          "description": "Total number of reviews submitted."
        },
        "averageRating": {
          "type": "number",
          "description": "Average rating across all reviews."
        }
      }
    },
    "Review": {
      "title": "Review",
      "description": "A user review/success story.",
      "type": "object",
      "properties": {
        "rating": {
          "type": "integer",
          "description": "Rating from 1 to 5."
        },
        "text": {
          "type": "string",
          "description": "Review comment text."
        },
        "name": {
          "type": "string",
          "description": "Name of the reviewer."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was submitted."
        }
      },
      "required": ["rating", "name", "createdAt"]
    },
    "ExplorePlan": {
      "title": "ExplorePlan",
      "description": "A curated fitness protocol for the explore page.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "level": { "type": "string" },
        "duration": { "type": "string" },
        "location": { "type": "string" },
        "dietType": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "downloads": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preview": { "type": "object" },
        "planData": { "type": "object" }
      },
      "required": ["title", "goal", "level", "duration", "location", "createdAt"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A fitness guide or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean" },
        "image": { "type": "string" }
      },
      "required": ["title", "content", "createdAt", "published"]
    },
    "ContactSubmission": {
      "title": "ContactSubmission",
      "description": "A message from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Collection of generated fitness plans."
    },
    "/explorePlans/{planId}": {
      "schema": "ExplorePlan",
      "description": "Curated protocols for the explore page."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of user reviews."
    },
    "/stats/global": {
      "schema": "Stats",
      "description": "Global stats like total plans and reviews."
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog articles."
    },
    "/contactSubmissions/{submissionId}": {
      "schema": "ContactSubmission",
      "description": "Collection of contact form submissions."
    }
  }
}
